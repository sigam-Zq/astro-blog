---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = Array.from(new Set(posts.flatMap(p => p.data.tags || []))).sort();

const url = new URL(Astro.request.url);
const selectedTags = url.searchParams.getAll('tag').flatMap(t => t.split(',')).filter(Boolean);

const filteredPosts = selectedTags.length > 0
	? posts.filter(post => selectedTags.some(tag => (post.data.tags || []).includes(tag)))
	: posts;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.tags-filter-bar {
				display: flex;
				align-items: center;
				gap: 1rem;
				padding: 1rem 0;
				margin-bottom: 1.5rem;
				flex-wrap: wrap;
			}
			.tags-label {
				font-size: 0.875rem;
				color: rgb(var(--gray));
				font-weight: 500;
				white-space: nowrap;
			}
			.tags-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				flex: 1;
			}
			.tag-chip {
				display: inline-flex;
				align-items: center;
				gap: 0.25rem;
				padding: 0.375rem 0.75rem;
				background: rgb(var(--gray-light));
				border-radius: 9999px;
				font-size: 0.875rem;
				color: rgb(var(--gray-dark));
				cursor: pointer;
				transition: all 0.15s ease;
				border: 1px solid transparent;
			}
			.tag-chip:hover {
				background: rgb(var(--gray));
				color: white;
				transform: scale(1.05);
			}
			.tag-chip.active {
				background: var(--accent);
				color: white;
				border-color: var(--accent);
			}
			.tag-chip.active:hover {
				background: var(--accent-dark);
				border-color: var(--accent-dark);
			}
			.tag-remove {
				font-size: 0.625rem;
				margin-left: 0.25rem;
				opacity: 0.7;
				cursor: pointer;
				transition: opacity 0.15s ease;
			}
			.tag-chip:hover .tag-remove,
			.tag-chip.active .tag-remove {
				opacity: 1;
			}
			.tag-remove:hover {
				transform: scale(1.2);
			}
			.clear-all-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.25rem;
				padding: 0.375rem 0.75rem;
				background: transparent;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 9999px;
				font-size: 0.75rem;
				color: rgb(var(--gray));
				cursor: pointer;
				transition: all 0.15s ease;
				white-space: nowrap;
			}
			.clear-all-btn:hover {
				border-color: rgb(var(--gray));
				color: rgb(var(--black));
				background: rgb(var(--gray-light));
			}
			#postsList {
				display: flex;
				flex-direction: column;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			#postsList > li {
				width: 100%;
				transition: opacity 0.2s ease;
			}
			#postsList > li[style*="display: none"] {
				display: none;
			}
			#postsList li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			#postsList li a {
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 2rem;
				padding: 1rem;
				border-radius: 12px;
				background: transparent;
			}
			#postsList li a:hover {
				background: rgba(var(--gray-light), 0.3);
				transform: translateX(4px);
			}
			.content-left {
				flex: 1;
			}
			#postsList li img {
				width: 240px;
				height: 135px;
				object-fit: cover;
				border-radius: 12px;
				margin-bottom: 0;
				transition: transform 0.3s ease, box-shadow 0.3s ease;
			}
			.title {
				margin: 0 0 0.25rem 0;
				color: var(--text-primary);
				line-height: 1.2;
				font-size: 1.75rem;
				font-weight: 600;
			}
			.date {
				margin: 0;
				color: var(--text-muted);
			}
			#postsList li a:hover .title {
				color: var(--accent);
				transition: color 0.2s ease;
			}
			#postsList li a:hover .date {
				color: var(--accent);
				transition: color 0.2s ease;
			}
			#postsList li a:hover img {
				box-shadow: var(--box-shadow);
				transform: scale(1.02);
				transition: transform 0.3s ease, box-shadow 0.3s ease;
			}
			.post-tags {
				display: flex;
				gap: 0.5rem;
				margin-top: 0.5rem;
				flex-wrap: wrap;
			}
			.post-tags span {
				font-size: 0.75rem;
				padding: 0.125rem 0.5rem;
				background: var(--bg-tertiary);
				border-radius: 9999px;
				color: var(--text-secondary);
				transition: background-color 0.15s ease, transform 0.15s ease, color 0.15s ease;
				cursor: default;
			}
			.post-tags span:hover {
				background: var(--accent);
				color: white;
				transform: scale(1.05);
			}
			@media (max-width: 720px) {
				.tags-filter-bar {
					gap: 0.75rem;
				}
				.tags-label {
					width: 100%;
				}
				.tag-chip {
					padding: 0.25rem 0.5rem;
					font-size: 0.8125rem;
				}
				#postsList {
					gap: 1rem;
				}
				#postsList li a {
					flex-direction: column;
					align-items: flex-start;
					gap: 1rem;
				}
				#postsList li img {
					width: 100%;
					height: auto;
				}
			}
			#postsList > li {
				opacity: 0;
				animation: fadeInUp 0.5s ease forwards;
			}
			#postsList > li:nth-child(1) { animation-delay: 0.1s; }
			#postsList > li:nth-child(2) { animation-delay: 0.15s; }
			#postsList > li:nth-child(3) { animation-delay: 0.2s; }
			#postsList > li:nth-child(4) { animation-delay: 0.25s; }
			#postsList > li:nth-child(5) { animation-delay: 0.3s; }
			#postsList > li:nth-child(6) { animation-delay: 0.35s; }
			#postsList > li:nth-child(7) { animation-delay: 0.4s; }
			#postsList > li:nth-child(8) { animation-delay: 0.45s; }
			#postsList > li:nth-child(9) { animation-delay: 0.5s; }
			#postsList > li:nth-child(10) { animation-delay: 0.55s; }
			@keyframes fadeInUp {
				from {
					opacity: 0;
					transform: translateY(20px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
			.post-item-hidden {
				display: none !important;
				opacity: 0;
				animation: none;
			}
			@media (prefers-reduced-motion: reduce) {
				#postsList > li {
					opacity: 1;
					animation: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main-content">
			<section>
				<div class="tags-filter-bar">
					<span class="tags-label">标签</span>
					<div class="tags-list">
						{allTags.map(tag => (
							<span
								class={`tag-chip ${selectedTags.includes(tag) ? 'active' : ''}`}
								data-tag={tag}
								onclick={`toggleTag('${tag}')`}
							>
								{tag}
								{selectedTags.includes(tag) && (
									<span class="tag-remove" onclick={`event.stopPropagation(); clearSingleTag('${tag}')`}>✕</span>
								)}
							</span>
						))}
					</div>
					{selectedTags.length > 0 && (
						<button class="clear-all-btn" onclick="clearTagFilter()">
							✕ 清除全部
						</button>
					)}
				</div>

				<script is:inline>
					function getSelectedTags() {
						return Array.from(document.querySelectorAll('.tag-chip.active'))
							.map(function(el) { return el.dataset.tag; });
					}

					function toggleTag(tag) {
						var selectedTags = getSelectedTags();

						if (selectedTags.includes(tag)) {
							clearSingleTag(tag);
						} else {
							selectedTags.push(tag);
							updateURLAndFilter(selectedTags);
						}
					}

					function clearSingleTag(tagValue) {
						var selectedTags = getSelectedTags().filter(function(t) { return t !== tagValue; });
						updateURLAndFilter(selectedTags);
					}

					function clearTagFilter() {
						updateURLAndFilter([]);
					}

					function updateURLAndFilter(selectedTags) {
						var url = new URL(window.location);
						if (selectedTags.length > 0) {
							url.searchParams.set('tag', selectedTags.join(','));
						} else {
							url.searchParams.delete('tag');
						}
						history.pushState({}, '', url);

						updateTagUI(selectedTags);
						filterPosts(selectedTags);
					}

					function updateTagUI(selectedTags) {
						document.querySelectorAll('.tag-chip').forEach(function(chip) {
							var tag = chip.dataset.tag;
							var isActive = selectedTags.includes(tag);

							if (isActive) {
								chip.classList.add('active');
								if (!chip.querySelector('.tag-remove')) {
									var removeSpan = document.createElement('span');
									removeSpan.className = 'tag-remove';
									removeSpan.textContent = '✕';
									removeSpan.onclick = function(e) {
										e.stopPropagation();
										clearSingleTag(tag);
									};
									chip.appendChild(removeSpan);
								}
							} else {
								chip.classList.remove('active');
								var removeSpan = chip.querySelector('.tag-remove');
								if (removeSpan) removeSpan.remove();
							}
						});

						var filterBar = document.querySelector('.tags-filter-bar');
						var clearBtn = filterBar.querySelector('.clear-all-btn');

						if (selectedTags.length > 0) {
							if (!clearBtn) {
								clearBtn = document.createElement('button');
								clearBtn.className = 'clear-all-btn';
								clearBtn.onclick = clearTagFilter;
								clearBtn.innerHTML = '✕ 清除全部';
								filterBar.appendChild(clearBtn);
							} else {
								clearBtn.style.display = '';
							}
						} else {
							if (clearBtn) clearBtn.style.display = 'none';
						}
					}

					function filterPosts(selectedTags) {
						var allPosts = document.querySelectorAll('#postsList > li[data-tags]');

						allPosts.forEach(function(li) {
							var postTags = (li.dataset.tags || '').split(',').filter(Boolean);

							if (selectedTags.length === 0) {
								li.classList.remove('post-item-hidden');
							} else if (selectedTags.some(function(tag) { return postTags.includes(tag); })) {
								li.classList.remove('post-item-hidden');
							} else {
								li.classList.add('post-item-hidden');
							}
						});
					}

					document.addEventListener('DOMContentLoaded', function() {
						var urlParams = new URLSearchParams(window.location.search);
						var selectedTags = urlParams.getAll('tag').flatMap(function(t) { return t.split(','); }).filter(Boolean);

						if (selectedTags.length > 0) {
							updateTagUI(selectedTags);
							filterPosts(selectedTags);
						}
					});
				</script>

				<ul id="postsList">
					{
						posts.map((post) => (
						!post.data.hidden &&
							<li data-tags={post.data.tags?.join(',') || ''}>
								<a href={`/blog/${post.id}/`}>
									<div class="content-left">
										<h4 class="title">{post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<div class="post-tags">
											{post.data.tags?.map(tag => (
												<span>{tag}</span>
											))}
										</div>
									</div>
									{post.data.heroImage ?
											<img width={720} height={360} src={post.data.heroImage} alt="" loading="lazy" />
										:
											<img width={720} height={360} src="/cat-1.svg" alt="" loading="lazy" />
										}
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>