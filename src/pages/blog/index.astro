---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogList from '../../components/BlogList';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="min-h-screen flex flex-col" style="background-color: var(--bg-primary);">
		<Header />
		<main id="main-content" style="width: 960px; max-width: calc(100% - 2em); margin: auto; padding: 3em 1em;">
			<section>
				<BlogList client:load posts={posts} postsPerPage={10} />
			</section>
		</main>
		<Footer />
	</body>
</html>