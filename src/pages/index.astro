---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestPosts = posts.slice(0, 3);
const tags = Array.from(new Set(posts.flatMap(p => p.data.tags)));
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-gray-50 min-h-screen flex flex-col">
		<Header />
		<main class="flex-1">
			<section class="py-20 px-4">
				<div class="max-w-4xl mx-auto text-center">
					<h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
						{SITE_TITLE}
					</h1>
					<p class="text-xl text-gray-600 mb-6">
						{SITE_DESCRIPTION}
					</p>
					<p class="text-gray-500 mb-8 max-w-2xl mx-auto leading-relaxed flex items-center justify-center gap-4">
						<img src="avatar.jpeg" alt="" class="w-16 h-16 rounded-full object-cover">
						这个世界会变好吗?
					</p>
					<a
						href="mailto:zq1024088055@163.com"
						class="inline-flex items-center gap-2 px-6 py-3 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition-colors"
					>
<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
						zq1024088055@163.com
					</a>
				</div>
			</section>

			<section class="py-16 px-4 bg-white">
				<div class="max-w-4xl mx-auto">
					<h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">标签</h2>
					<div class="flex flex-wrap justify-center gap-3">
						{tags.map(tag => (
							<a
								href={`/blog?tag=${tag}`}
								class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full hover:bg-gray-200 transition-colors text-sm font-medium"
							>
								{tag}
							</a>
						))}
					</div>
				</div>
			</section>

			<section class="py-16 px-4">
				<div class="max-w-4xl mx-auto">
					<h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">最新文章</h2>
					<div class="grid gap-6 md:grid-cols-3">
						{latestPosts.map(post => (
							<a
								href={`/blog/${post.slug}`}
								class="block p-6 bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow"
							>
								<div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
									</svg>
									<time datetime={post.data.pubDate.toISOString()}>
										{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
									</time>
								</div>
								<h3 class="text-lg font-semibold text-gray-900 mb-2 line-clamp-2">
									{post.data.title}
								</h3>
								<p class="text-gray-600 text-sm line-clamp-3">
									{post.data.description}
								</p>
							</a>
						))}
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>