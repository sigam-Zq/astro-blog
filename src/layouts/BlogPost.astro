---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const currentIndex = allPosts.findIndex(p => p.data.title === title);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.prose {
				color: rgb(var(--gray-dark));
			}
			.prose :global(h1),
			.prose :global(h2),
			.prose :global(h3),
			.prose :global(h4),
			.prose :global(h5),
			.prose :global(h6) {
				color: rgb(var(--black));
			}
			.prose :global(a) {
				color: var(--accent);
				text-decoration: underline;
				text-underline-offset: 2px;
			}
			.prose :global(a:hover) {
				color: var(--accent-dark);
			}
			.post-nav-card {
				transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
			}
			.post-nav-card:hover {
				background-color: rgb(var(--gray-light));
				transform: translateX(4px);
				box-shadow: 0 4px 12px rgba(var(--gray), 15%);
			}
			.post-nav-card-next:hover {
				transform: translateX(-4px);
			}
		</style>
	</head>

	<body class="bg-white min-h-screen flex flex-col">
		<Header />

		<main class="flex-1 w-full max-w-4xl mx-auto px-4 py-8">
			<article>
				{heroImage && (
					<div class="mb-10 rounded-2xl overflow-hidden shadow-lg">
						<img
							width={1020}
							height={510}
							src={heroImage}
							alt=""
							class="w-full h-auto object-cover"
							loading="eager"
						/>
					</div>
				)}

				<header class="text-center mb-12 pb-8 border-b border-gray-200">
					<div class="flex flex-col items-center gap-2 mb-6">
						<time datetime={pubDate.toISOString()} class="text-sm text-gray-500">
							<FormattedDate date={pubDate} />
						</time>
						{updatedDate && (
							<span class="text-xs text-gray-400 italic">
								更新于 <FormattedDate date={updatedDate} />
							</span>
						)}
					</div>

					<h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6 leading-tight">
						{title}
					</h1>

					{tags && tags.length > 0 && (
						<div class="flex flex-wrap justify-center gap-2">
							{tags.map(tag => (
								<a
									href={`/blog?tag=${tag}`}
									class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium
										   hover:bg-gray-200 hover:text-gray-900 hover:scale-105 active:scale-95
										   transition-all duration-150"
								>
									{tag}
								</a>
							))}
						</div>
					)}
				</header>

				<div class="prose max-w-3xl mx-auto">
					<slot />
				</div>

				{(prevPost || nextPost) && (
					<nav class="flex flex-col sm:flex-row justify-between gap-4 mt-16 pt-8 border-t border-gray-200">
						{prevPost ? (
							<a
								href={`/blog/${prevPost.id}/`}
								class="post-nav-card flex-1 p-5 rounded-xl border border-gray-200 text-left group"
							>
								<span class="text-xs text-gray-500 mb-1 block group-hover:text-gray-700">
									← 上一篇
								</span>
								<span class="font-medium text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-2">
									{prevPost.data.title}
								</span>
							</a>
						) : (
							<div class="flex-1"></div>
						)}

						{nextPost && (
							<a
								href={`/blog/${nextPost.id}/`}
								class="post-nav-card post-nav-card-next flex-1 p-5 rounded-xl border border-gray-200 text-right group"
							>
								<span class="text-xs text-gray-500 mb-1 block group-hover:text-gray-700">
									下一篇 →
								</span>
								<span class="font-medium text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-2">
									{nextPost.data.title}
								</span>
							</a>
						)}
					</nav>
				)}

				<div class="text-center mt-8">
					<a
						href="/blog"
						class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900
						       hover:gap-3 transition-all duration-200"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-4 w-4"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
						</svg>
						返回博客列表
					</a>
				</div>
			</article>
		</main>

		<Footer />
	</body>
</html>
