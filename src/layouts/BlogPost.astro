---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const currentIndex = allPosts.findIndex(p => p.data.title === title);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.prose {
				color: var(--text-primary);
				max-width: 720px;
			}
			.prose :global(h1),
			.prose :global(h2),
			.prose :global(h3),
			.prose :global(h4),
			.prose :global(h5),
			.prose :global(h6) {
				color: var(--text-primary);
			}
			.prose :global(a) {
				color: var(--accent);
				text-decoration: underline;
				text-underline-offset: 2px;
			}
			.prose :global(a:hover) {
				color: var(--accent-dark);
			}
			.prose :global(pre) {
				max-width: 900px;
				margin-left: -90px;
			}
			@media (max-width: 900px) {
				.prose :global(pre) {
					margin-left: 0;
					max-width: 100%;
				}
			}
			.prose :global(p) {
				color: var(--text-primary);
			}
			.prose :global(ul),
			.prose :global(ol) {
				color: var(--text-primary);
			}
			.prose :global(blockquote) {
				border-left-color: var(--accent);
				color: var(--text-secondary);
			}
			.prose :global(hr) {
				border-color: var(--border-color);
			}
			.post-nav-card {
				transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
				background: var(--bg-primary);
				border-color: var(--border-color);
			}
			.post-nav-card:hover {
				background-color: var(--bg-secondary);
				transform: translateX(4px);
				box-shadow: var(--shadow-md);
			}
			.post-nav-card-next:hover {
				transform: translateX(-4px);
			}
			.post-nav-card :global(.nav-title) {
				color: var(--text-primary);
			}
			.post-nav-card :global(.nav-label) {
				color: var(--text-secondary);
			}
			.header-content {
				color: var(--text-muted);
			}
			.updated-date {
				color: var(--text-muted);
			}
			.title-text {
				color: var(--text-primary);
			}
			.tag-chip {
				background: var(--bg-secondary);
				color: var(--text-secondary);
				border-color: var(--border-color);
			}
			.tag-chip:hover {
				background: var(--bg-tertiary);
				color: var(--text-primary);
			}
			.back-link {
				color: var(--text-secondary);
			}
			.back-link:hover {
				color: var(--text-primary);
			}
		</style>
	</head>

	<body class="min-h-screen flex flex-col" style="background-color: var(--bg-primary);">
		<Header />

		<main class="flex-1 w-full max-w-4xl mx-auto px-4 py-8">
			<article>
				{heroImage && (
					<div class="mb-10 rounded-2xl overflow-hidden shadow-lg">
						<img
							width={1020}
							height={510}
							src={heroImage}
							alt=""
							class="w-full h-auto object-cover"
							loading="eager"
						/>
					</div>
				)}

				<header class="text-center mb-12 pb-8 border-b" style="border-color: var(--border-color);">
					<div class="flex flex-col items-center gap-2 mb-6">
						<time datetime={pubDate.toISOString()} class="text-sm header-content">
							<FormattedDate date={pubDate} />
						</time>
						{updatedDate && (
							<span class="text-xs updated-date italic">
								更新于 <FormattedDate date={updatedDate} />
							</span>
						)}
					</div>

					<h1 class="text-3xl md:text-4xl font-bold title-text mb-6 leading-tight">
						{title}
					</h1>

					{tags && tags.length > 0 && (
						<div class="flex flex-wrap justify-center gap-2">
							{tags.map(tag => (
								<a
									href={`/blog?tag=${tag}`}
									class="tag-chip px-3 py-1 rounded-full text-xs font-medium
										   hover:scale-105 active:scale-95
										   transition-all duration-150"
								>
									{tag}
								</a>
							))}
						</div>
					)}
				</header>

				<div class="prose mx-auto">
					<slot />
				</div>

				{(prevPost || nextPost) && (
					<nav class="flex flex-col sm:flex-row justify-between gap-4 mt-16 pt-8 border-t" style="border-color: var(--border-color);">
						{prevPost ? (
							<a
								href={`/blog/${prevPost.id}/`}
								class="post-nav-card flex-1 p-5 rounded-xl border text-left group"
							>
								<span class="nav-label text-xs mb-1 block">
									← 上一篇
								</span>
								<span class="nav-title font-medium transition-colors line-clamp-2">
									{prevPost.data.title}
								</span>
							</a>
						) : (
							<div class="flex-1"></div>
						)}

						{nextPost && (
							<a
								href={`/blog/${nextPost.id}/`}
								class="post-nav-card post-nav-card-next flex-1 p-5 rounded-xl border text-right group"
							>
								<span class="nav-label text-xs mb-1 block">
									下一篇 →
								</span>
								<span class="nav-title font-medium transition-colors line-clamp-2">
									{nextPost.data.title}
								</span>
							</a>
						)}
					</nav>
				)}

				<div class="text-center mt-8">
					<a
						href="/blog"
						class="back-link inline-flex items-center gap-2 text-sm
						       hover:gap-3 transition-all duration-200"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-4 w-4"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
						</svg>
						返回博客列表
					</a>
				</div>
			</article>
		</main>

		<Footer />
	</body>
</html>
